# Stage 1: Build Angular with SSR
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build -- --configuration=production

# Stage 2: Run Node.js SSR server
FROM node:20-alpine
WORKDIR /app

# Copy the built application
COPY --from=build /app/dist/taskboard-frontend /app/dist/taskboard-frontend
COPY --from=build /app/package*.json ./

# Install only production dependencies
RUN npm ci --omit=dev

# Set the port for the SSR server
ENV PORT=4200

EXPOSE 4200

# Start the SSR server
CMD ["node", "dist/taskboard-frontend/server/server.mjs"]
